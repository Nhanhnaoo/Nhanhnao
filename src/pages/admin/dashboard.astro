---
// src/pages/admin/dashboard.astro
import { env } from "cloudflare:workers";
import Layout from "../../layouts/Layout.astro";

const { DB } = env;
if (!DB) return new Response("Lỗi kết nối Cloudflare D1 Database");

// -------------------------------------------------------------
// 🔐 1. MẬT KHẨU BẢO VỆ (SESSION AUTH) LỚP CƠ BẢN
// -------------------------------------------------------------
const cookies = Astro.cookies;
let isAuthenticated = cookies.get("admin_session")?.value === "true";

let message = "";
let messageType = "success"; 
let editArticleData: any = null; // Biến tạm phục vụ form Chỉnh sửa bài viết

// Xử lý đăng nhập / Đăng xuất / Toàn bộ hành động quản trị
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    // Hành động Đăng nhập
    if (action === "login") {
      const password = formData.get("password") as string;
      // Bạn có thể đổi mật khẩu 'admin2026' này thành mật khẩu của bạn
      if (password === "admin2026") {
        Astro.cookies.set("admin_session", "true", { path: "/admin", maxAge: 60 * 60 * 24 });
        isAuthenticated = true;
        message = "🔐 Đăng nhập thành công!";
      } else {
        throw new Error("Mật khẩu không chính xác!");
      }
    }

    // Hành động Đăng xuất
    if (action === "logout") {
      Astro.cookies.delete("admin_session", { path: "/admin" });
      isAuthenticated = false;
      return Astro.redirect("/admin/dashboard");
    }

    // NẾU ĐÃ ĐĂNG NHẬP THÌ MỚI CHO CHẠY CÁC LỆNH DƯỚI ĐÂY
    if (isAuthenticated) {
      
      // Lệnh 2: Cập nhật cấu hình & API Key (Cloudinary / Crawler)
      if (action === "update_settings") {
        const siteName = formData.get("site_name") as string;
        const adsTop = formData.get("ads_top") as string;
        const adsInfeed = formData.get("ads_infeed") as string;
        const cldCloudName = formData.get("cld_cloud_name") as string;
        const cldApiKey = formData.get("cld_api_key") as string;
        const cldApiSecret = formData.get("cld_api_secret") as string;

        await DB.prepare("INSERT OR REPLACE INTO settings (key, value) VALUES ('site_name', ?)").bind(siteName).run();
        await DB.prepare("INSERT OR REPLACE INTO settings (key, value) VALUES ('ads_top', ?)").bind(adsTop).run();
        await DB.prepare("INSERT OR REPLACE INTO settings (key, value) VALUES ('ads_infeed', ?)").bind(adsInfeed).run();
        await DB.prepare("INSERT OR REPLACE INTO settings (key, value) VALUES ('cld_cloud_name', ?)").bind(cldCloudName).run();
        await DB.prepare("INSERT OR REPLACE INTO settings (key, value) VALUES ('cld_api_key', ?)").bind(cldApiKey).run();
        await DB.prepare("INSERT OR REPLACE INTO settings (key, value) VALUES ('cld_api_secret', ?)").bind(cldApiSecret).run();
        
        message = "🎉 Đã lưu toàn bộ Cấu hình hệ thống & API Cloud Đám mây!";
      }

      // Lệnh 3: Đưa dữ liệu bài viết lên Form để chuẩn bị SỬA (Edit)
      if (action === "load_edit_article") {
        const id = formData.get("article_id");
        editArticleData = await DB.prepare("SELECT * FROM articles WHERE id = ?").bind(id).first();
      }

      // Lệnh 4: Thực thi CẬP NHẬT bài viết sau khi sửa
      if (action === "submit_edit_article") {
        const id = formData.get("article_id");
        const title = formData.get("title") as string;
        const sapo = formData.get("sapo") as string;
        let imageUrl = formData.get("image_url") as string;
        const catId = formData.get("category_id");

        // 📷 UPLOAD ẢNH LÊN CLOUD API (CLOUDINARY) NẾU CÓ FILE MỚI
        const imageFile = formData.get("image_file") as File;
        if (imageFile && imageFile.size > 0) {
          const { results: keys } = await DB.prepare("SELECT * FROM settings WHERE key IN ('cld_cloud_name', 'cld_api_key')").all();
          const cldConfigs = Object.fromEntries(keys.map((s: any) => [s.key, s.value]));
          
          if (cldConfigs.cld_cloud_name && cldConfigs.cld_api_key) {
            // Đẩy file lên Cloudinary thông qua API Rest
            const cldData = new FormData();
            cldData.append("file", imageFile);
            cldData.append("upload_preset", "unsigned_preset_baomoi"); // Tạo preset unsigned trên Cloudinary của bạn
            
            const cldRes = await fetch(`https://api.cloudinary.com/v1_1/${cldConfigs.cld_cloud_name}/image/upload`, {
              method: "POST",
              body: cldData
            });
            if (cldRes.ok) {
              const cldJson = await cldRes.json() as any;
              imageUrl = cldJson.secure_url; // Đổi thành link ảnh Cloud mây CDN siêu tốc!
            }
          }
        }

        await DB.prepare("UPDATE articles SET title = ?, sapo = ?, image_url = ?, category_id = ? WHERE id = ?")
          .bind(title, sapo, imageUrl, catId, id)
          .run();
        message = "📝 Đã cập nhật nội dung và hình ảnh bài viết thành công!";
      }

      // Lệnh 5: Xóa bài viết
      if (action === "delete_article") {
        const articleId = formData.get("article_id");
        await DB.prepare("DELETE FROM articles WHERE id = ?").bind(articleId).run();
        message = "🗑️ Đã xóa bài viết khỏi hệ thống.";
      }
    }
  } catch (error: any) {
    message = `❌ Thao tác thất bại: ${error.message}`;
    messageType = "error";
  }
}

// -------------------------------------------------------------
// 📊 LẤY DỮ LIỆU ĐỂ HIỂN THỊ LÊN UI (CHỈ QUÉT KHI ĐÃ AUTH)
// -------------------------------------------------------------
let configs: any = {};
let categories: any[] = [];
let articles: any[] = [];

if (isAuthenticated) {
  const { results: settingsRaw } = await DB.prepare("SELECT * FROM settings").all();
  configs = Object.fromEntries(settingsRaw.map((s: any) => [s.key, s.value]));
  const { results: catRaw } = await DB.prepare("SELECT * FROM categories").all();
  categories = catRaw;
  const { results: artRaw } = await DB.prepare(`
    SELECT a.id, a.title, a.image_url, a.view_count, c.name as category_name 
    FROM articles a
    JOIN categories c ON a.category_id = c.id
    ORDER BY a.id DESC LIMIT 8
  `).all();
  articles = artRaw;
}
---

<Layout title="Bảng Quản Trị Bảo Mật - Báo Mới AI">
  
  {!isAuthenticated ? (
    <div class="max-w-md mx-auto my-20 bg-white p-8 rounded-2xl border border-gray-100 shadow-xl space-y-6">
      <div class="text-center">
        <h2 class="text-2xl font-black text-gray-900">🔐 HỆ THỐNG BẢO MẬT</h2>
        <p class="text-xs text-gray-400 mt-1">Vui lòng điền mật khẩu tối cao để truy cập hệ thống quản trị</p>
      </div>
      {message && <div class="p-3 rounded-lg text-xs font-bold text-center bg-red-50 text-red-700">{message}</div>}
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="login" />
        <div>
          <label class="block text-xs font-bold text-gray-500 mb-1">MẬT KHẨU TRUY CẬP</label>
          <input type="password" name="password" placeholder="••••••••" class="w-full p-3 text-sm rounded-lg border border-gray-200 focus:outline-none focus:border-red-500 bg-gray-50" required />
        </div>
        <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-lg text-sm transition-all cursor-pointer shadow-md">
          XÁC THỰC ĐĂNG NHẬP
        </button>
      </form>
    </div>
  ) : (
    
    // GIAO DIỆN CHÍNH: KHI ĐÃ ĐĂNG NHẬP THÀNH CÔNG
    <div class="space-y-8">
      
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between border-b pb-4 gap-4">
        <div>
          <h1 class="text-3xl font-black tracking-tight text-gray-900">ADMIN CONTROL CENTER</h1>
          <p class="text-sm text-gray-500">Hệ thống quản trị mật khẩu, API Đám mây Cloudinary và chỉnh sửa bài báo</p>
        </div>
        <form method="POST">
          <input type="hidden" name="action" value="logout" />
          <button type="submit" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-bold px-4 py-2 rounded-lg cursor-pointer transition-colors">
            🔒 Đăng Xuất Hệ Thống
          </button>
        </form>
      </div>

      {message && (
        <div class={`p-4 rounded-xl text-sm font-semibold ${messageType === 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200'}`}>
          {message}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-6">
          
          {/* NẾU ĐANG KÍCH HOẠT CHẾ ĐỘ SỬA BÀI VIẾT */}
          {editArticleData && (
            <div class="bg-gradient-to-r from-amber-50 to-orange-50 p-6 rounded-2xl border border-amber-200 shadow-sm space-y-4">
              <h3 class="text-lg font-black text-amber-900 flex items-center gap-2">📝 Đang chỉnh sửa bài viết (ID: {editArticleData.id})</h3>
              <form method="POST" enctype="multipart/form-data" class="space-y-4">
                <input type="hidden" name="action" value="submit_edit_article" />
                <input type="hidden" name="article_id" value={editArticleData.id} />
                <input type="hidden" name="image_url" value={editArticleData.image_url} />

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                  <div class="sm:col-span-2">
                    <label class="block text-xs font-bold text-amber-800 mb-1">Tiêu đề bài viết</label>
                    <input type="text" name="title" value={editArticleData.title} class="w-full p-2.5 text-sm bg-white rounded-lg border border-amber-200 focus:outline-none" required />
                  </div>
                  <div>
                    <label class="block text-xs font-bold text-amber-800 mb-1">Chuyên mục</label>
                    <select name="category_id" class="w-full p-2.5 text-sm bg-white rounded-lg border border-amber-200 focus:outline-none">
                      {categories.map((c: any) => (
                        <option value={c.id} selected={c.id === editArticleData.category_id}>{c.name}</option>
                      ))}
                    </select>
                  </div>
                </div>

                <div>
                  <label class="block text-xs font-bold text-amber-800 mb-1">Đoạn tóm tắt (Sapo)</label>
                  <textarea name="sapo" rows="3" class="w-full p-2.5 text-sm bg-white rounded-lg border border-amber-200 focus:outline-none" required>{editArticleData.sapo}</textarea>
                </div>

                <div class="bg-white p-4 rounded-xl border border-amber-200 flex flex-col sm:flex-row items-center gap-4">
                  <img src={editArticleData.image_url} class="w-24 h-16 object-cover rounded-lg border bg-gray-100" />
                  <div class="flex-grow w-full">
                    <label class="block text-xs font-bold text-gray-600 mb-1">Thay ảnh mới (Tự động đẩy lên Cloud CDN Cloudinary)</label>
                    <input type="file" name="image_file" accept="image/*" class="w-full text-xs text-gray-500 file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-amber-100 file:text-amber-700 hover:file:bg-amber-200 cursor-pointer" />
                  </div>
                </div>

                <div class="flex gap-2 justify-end">
                  <a href="/admin/dashboard" class="bg-gray-200 text-gray-700 font-bold text-xs px-4 py-2.5 rounded-lg">Hủy bỏ</a>
                  <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white font-bold text-xs px-5 py-2.5 rounded-lg cursor-pointer">Lưu Thay Đổi</button>
                </div>
              </form>
            </div>
          )}

          {/* DANH SÁCH BÀI VIẾT HIỆN CÓ ĐỂ SỬA / XÓA / QUẢN LÝ ẢNH */}
          <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm space-y-4">
            <h2 class="text-lg font-bold text-gray-900 border-b pb-2">📰 Quản lý danh sách Bài viết & Hình ảnh</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {articles.map((art: any) => (
                <div class="p-3 rounded-xl bg-gray-50 border border-gray-100 flex gap-3 group shadow-xs">
                  <div class="w-20 h-16 overflow-hidden rounded-lg bg-gray-200 flex-shrink-0 relative">
                    <img src={art.image_url} class="w-full h-full object-cover" />
                    {art.image_url.includes('cloudinary.com') && (
                      <span class="absolute bottom-0 right-0 bg-blue-600 text-[8px] font-bold text-white px-1 rounded-tl-sm">Cloud</span>
                    )}
                  </div>
                  <div class="flex flex-col justify-between overflow-hidden flex-grow">
                    <h4 class="text-xs font-bold text-gray-900 truncate">{art.title}</h4>
                    <p class="text-[10px] text-gray-400">Chuyên mục: {art.category_name} | 👁️ {art.view_count}</p>
                    <div class="flex gap-2 justify-end mt-1">
                      {/* Form nạp dữ liệu sửa */}
                      <form method="POST">
                        <input type="hidden" name="action" value="load_edit_article" />
                        <input type="hidden" name="article_id" value={art.id} />
                        <button type="submit" class="text-[10px] font-bold bg-amber-50 text-amber-700 hover:bg-amber-100 px-2 py-0.5 rounded cursor-pointer">Sửa</button>
                      </form>
                      {/* Form xóa */}
                      <form method="POST" onsubmit="return confirm('Xóa vĩnh viễn bài viết này?');">
                        <input type="hidden" name="action" value="delete_article" />
                        <input type="hidden" name="article_id" value={art.id} />
                        <button type="submit" class="text-[10px] font-bold bg-red-50 text-red-600 hover:bg-red-100 px-2 py-0.5 rounded cursor-pointer">Xóa</button>
                      </form>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm space-y-4">
            <h2 class="text-base font-black text-gray-900 border-b pb-2 flex items-center gap-2">🛠️ Cài đặt API Đám Mây & Ads</h2>
            <form method="POST" class="space-y-4">
              <input type="hidden" name="action" value="update_settings" />
              
              <div>
                <label class="block text-[10px] font-bold text-gray-400 uppercase">Tên website</label>
                <input type="text" name="site_name" value={configs.site_name || "Báo Mới AI"} class="w-full p-2 text-xs rounded-lg border border-gray-200 bg-gray-50 focus:outline-none" />
              </div>

              <div class="p-3 bg-blue-50/50 rounded-xl border border-blue-100 space-y-2">
                <span class="text-xs font-bold text-blue-900 flex items-center gap-1">☁️ Cloudinary Image API</span>
                <div>
                  <label class="block text-[9px] font-bold text-blue-700">Cloud Name</label>
                  <input type="text" name="cld_cloud_name" value={configs.cld_cloud_name || ""} placeholder="Nhập Cloud Name" class="w-full p-1.5 text-xs bg-white rounded-md border border-blue-200 focus:outline-none font-mono" />
                </div>
                <div>
                  <label class="block text-[9px] font-bold text-blue-700">API Key</label>
                  <input type="text" name="cld_api_key" value={configs.cld_api_key || ""} placeholder="Nhập API Key" class="w-full p-1.5 text-xs bg-white rounded-md border border-blue-200 focus:outline-none font-mono" />
                </div>
                <div>
                  <label class="block text-[9px] font-bold text-blue-700">API Secret</label>
                  <input type="password" name="cld_api_secret" value={configs.cld_api_secret || ""} placeholder="••••••••••••" class="w-full p-1.5 text-xs bg-white rounded-md border border-blue-200 focus:outline-none font-mono" />
                </div>
              </div>

              <div>
                <label class="block text-[10px] font-bold text-gray-400 uppercase">HTML Ads Top Banner</label>
                <textarea name="ads_top" rows="2" class="w-full p-2 text-xs font-mono rounded-lg border border-gray-200 bg-gray-50 focus:outline-none">{configs.ads_top || ''}</textarea>
              </div>

              <div>
                <label class="block text-[10px] font-bold text-gray-400 uppercase">HTML Ads Infeed Banner</label>
                <textarea name="ads_infeed" rows="2" class="w-full p-2 text-xs font-mono rounded-lg border border-gray-200 bg-gray-50 focus:outline-none">{configs.ads_infeed || ''}</textarea>
              </div>

              <button type="submit" class="w-full bg-gray-900 hover:bg-gray-800 text-white font-bold text-xs py-2 rounded-lg cursor-pointer shadow-xs transition-colors">
                💾 Lưu Toàn Bộ Cấu Hình & API
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  )}
</Layout>