---
// src/layouts/Layout.astro
import '../global.css';

interface Props {
	title?: string;
}

const { title = "Báo Mới AI - Trang tin tức tổng hợp" } = Astro.props;
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-50 text-gray-900 flex flex-col min-h-screen font-sans antialiased">
		
		<header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				<div class="flex items-center gap-8">
					<a href="/" class="text-2xl font-black tracking-tight text-red-600 flex items-center gap-1 hover:opacity-90">
						BAOMOI <span class="bg-red-600 text-white text-xs font-bold px-1.5 py-0.5 rounded">AI</span>
					</a>
					<nav class="hidden md:flex items-center gap-6 text-sm font-bold text-gray-600">
						<a href="/?cat=1" class="hover:text-red-600 transition-colors">Thời sự</a>
						<a href="/?cat=2" class="hover:text-red-600 transition-colors">Công nghệ</a>
						<a href="/?cat=3" class="hover:text-red-600 transition-colors">Kinh tế</a>
						<a href="/?cat=4" class="hover:text-red-600 transition-colors">Sức khỏe</a>
						<a href="/?cat=5" class="hover:text-red-600 transition-colors">Giải trí</a>
					</nav>
				</div>
				
				<form action="/" method="GET" class="flex items-center gap-2">
					<div class="relative">
						<input 
							type="text" 
							name="search"
							placeholder="Tìm kiếm tin tức..." 
							class="w-48 sm:w-64 pl-4 pr-10 py-1.5 text-sm rounded-full border border-gray-200 focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 bg-gray-50 transition-all"
						/>
						<button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-red-600">
							🔍
						</button>
					</div>
				</form>
			</div>
		</header>
		
		<main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
			<slot />
		</main>

		<footer class="bg-gray-900 text-gray-400 border-t border-gray-800 mt-auto">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 border-b border-gray-800 pb-8 text-sm">
					<div>
						<h4 class="text-white font-bold mb-3">Về Báo Mới AI</h4>
						<p class="leading-relaxed text-gray-400">Hệ thống tổng hợp tin tức tự động ứng dụng Trí tuệ nhân tạo thế hệ mới, cập nhật liên tục 24/7 từ các nguồn báo chí uy tín tại Việt Nam.</p>
					</div>
					<div>
						<h4 class="text-white font-bold mb-3">Chuyên mục chính</h4>
						<div class="grid grid-cols-2 gap-2">
							<a href="/?cat=1" class="hover:text-white">Khoa học - Thời sự</a>
							<a href="/?cat=2" class="hover:text-white">Công nghệ mới</a>
							<a href="/?cat=3" class="hover:text-white">Kinh tế thị trường</a>
							<a href="/?cat=4" class="hover:text-white">Sức khỏe đời sống</a>
						</div>
					</div>
					<div>
						<h4 class="text-white font-bold mb-3">Liên hệ & Bản quyền</h4>
						<p>Email: contact@baomoiai.vn</p>
						<p class="mt-2">Mọi nội dung đều thuộc quyền sở hữu của các cơ quan báo chí chính thống.</p>
					</div>
				</div>
				<div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
					<p>© 2026 BAOMOI AI Portal. Phát triển trên nền tảng Astro & Cloudflare D1.</p>
					<div class="flex gap-6">
						<a href="#" class="hover:text-white">Điều khoản sử dụng</a>
						<a href="#" class="hover:text-white">Chính sách bảo mật</a>
					</div>
				</div>
			</div>
		</footer>

	</body>
</html>

<style is:global>
	@tailwind base;
	@tailwind components;
	@tailwind utilities;
</style>